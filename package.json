{
  "name": "@veldica/prose-analyzer",
  "version": "1.1.0",
  "description": "Deterministic prose style metrics for measuring variety, density, repetition, and narrative texture. Designed for AI editorial pipelines and writing tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lexical": {
      "types": "./dist/lexical.d.ts",
      "import": "./dist/lexical.js"
    },
    "./narrative": {
      "types": "./dist/narrative.d.ts",
      "import": "./dist/narrative.js"
    },
    "./categorization": {
      "types": "./dist/categorization.d.ts",
      "import": "./dist/categorization.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "prose-analysis",
    "style-metrics",
    "lexical-diversity",
    "narrative-analysis",
    "text-analysis",
    "writing-tools",
    "editorial-tooling",
    "deterministic",
    "nlp",
    "ttr",
    "mattr"
  ],
  "license": "MIT",
  "author": {
    "name": "Veldica",
    "email": "opensource@veldica.com",
    "url": "https://veldica.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veldica/prose-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/veldica/prose-analyzer/issues"
  },
  "homepage": "https://veldica.com/prose-analyzer",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@veldica/prose-tokenizer": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
